<ShowPlanXML xmlns="http://schemas.microsoft.com/sqlserver/2004/07/showplan" Version="1.564" Build="16.0.4225.2"><BatchSequence><Batch><Statements><StmtSimple StatementText="SELECT&#xd;&#xa;    o_year,&#xd;&#xa;    SUM(&#xd;&#xa;        CASE&#xd;&#xa;            WHEN nation = &apos;BRAZIL&apos;&#xd;&#xa;            THEN volume&#xd;&#xa;            ELSE 0&#xd;&#xa;        END&#xd;&#xa;    ) * 1.0 / SUM(volume) AS mkt_share&#xd;&#xa;FROM (&#xd;&#xa;    SELECT&#xd;&#xa;        YEAR(o.o_orderdate) AS o_year,&#xd;&#xa;        l.l_extendedprice * (1 - l.l_discount) AS volume,&#xd;&#xa;        n2.n_name AS nation&#xd;&#xa;    FROM&#xd;&#xa;        dbo.part     p,&#xd;&#xa;        dbo.supplier s,&#xd;&#xa;        dbo.lineitem l,&#xd;&#xa;        dbo.orders   o,&#xd;&#xa;        dbo.customer c,&#xd;&#xa;        dbo.nation   n1,&#xd;&#xa;        dbo.nation   n2,&#xd;&#xa;        dbo.region   r&#xd;&#xa;    WHERE&#xd;&#xa;            p.p_partkey = l.l_partkey&#xd;&#xa;        AND s.s_suppkey = l.l_suppkey&#xd;&#xa;        AND l.l_orderkey = o.o_orderkey&#xd;&#xa;        AND o.o_custkey = c.c_custkey&#xd;&#xa;        AND c.c_nationkey = n1.n_nationkey&#xd;&#xa;        AND n1.n_regionkey = r.r_regionkey&#xd;&#xa;        AND r.r_name = &apos;AMERICA&apos;&#xd;&#xa;        AND s.s_nationkey = n2.n_nationkey&#xd;&#xa;        AND o.o_orderdate BETWEEN &apos;1995-01-01&apos; AND &apos;1996-12-31&apos;&#xd;&#xa;        AND p.p_type = &apos;ECONOMY ANODIZED STEEL&apos;&#xd;&#xa;) AS all_nations&#xd;&#xa;GROUP BY&#xd;&#xa;    o_year&#xd;&#xa;ORDER BY&#xd;&#xa;    o_year" StatementId="1" StatementCompId="4" StatementType="SELECT" StatementSqlHandle="0x09006CE3CD7E0DF85D268F5CAA1A3211B5B50000000000000000000000000000000000000000000000000000" DatabaseContextSettingsId="7" ParentObjectId="0" StatementParameterizationType="0" RetrievedFromCache="true" StatementSubTreeCost="101.829" StatementEstRows="2" SecurityPolicyApplied="true" QueryCompilationReplay="1" StatementOptmLevel="FULL" QueryHash="0x3F2872F64967E756" QueryPlanHash="0x1994A00DCD25C116" StatementOptmEarlyAbortReason="TimeOut" CardinalityEstimationModelVersion="160" BatchModeOnRowStoreUsed="true"><StatementSetOptions QUOTED_IDENTIFIER="true" ARITHABORT="true" CONCAT_NULL_YIELDS_NULL="true" ANSI_NULLS="true" ANSI_PADDING="true" ANSI_WARNINGS="true" NUMERIC_ROUNDABORT="false"></StatementSetOptions><QueryPlan DegreeOfParallelism="12" MemoryGrant="296840" CachedPlanSize="488" CompileTime="287" CompileCPU="283" CompileMemory="30304"><ThreadStat Branches="2" UsedThreads="24"><ThreadReservation NodeId="0" ReservedThreads="25"></ThreadReservation></ThreadStat><MissingIndexes><MissingIndexGroup Impact="15.8227"><MissingIndex Database="[TPCH]" Schema="[dbo]" Table="[orders]"><ColumnGroup Usage="INEQUALITY"><Column Name="[O_OrderDate]" ColumnId="5"></Column></ColumnGroup><ColumnGroup Usage="INCLUDE"><Column Name="[O_CustKey]" ColumnId="2"></Column></ColumnGroup></MissingIndex></MissingIndexGroup><MissingIndexGroup Impact="17.0993"><MissingIndex Database="[TPCH]" Schema="[dbo]" Table="[orders]"><ColumnGroup Usage="EQUALITY"><Column Name="[O_CustKey]" ColumnId="2"></Column></ColumnGroup><ColumnGroup Usage="INEQUALITY"><Column Name="[O_OrderDate]" ColumnId="5"></Column></ColumnGroup></MissingIndex></MissingIndexGroup></MissingIndexes><MemoryGrantInfo SerialRequiredMemory="10392" SerialDesiredMemory="177464" RequiredMemory="129704" DesiredMemory="296840" RequestedMemory="296840" GrantWaitTime="0" MaxQueryMemory="1184888" GrantedMemory="296840" MaxUsedMemory="16000" LastRequestedMemory="0" IsMemoryGrantFeedbackAdjusted="No: First Execution"></MemoryGrantInfo><OptimizerHardwareDependentProperties EstimatedAvailableMemoryGrant="107281" EstimatedPagesCached="80460" EstimatedAvailableDegreeOfParallelism="6" MaxCompileMemory="4553360"></OptimizerHardwareDependentProperties><OptimizerStatsUsage><StatisticsInfo LastUpdate="2026-01-28T01:36:28.21" ModificationCount="0" SamplingPercent="34.0085" Statistics="[_WA_Sys_0